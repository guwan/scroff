<Window x:Class="Scroff.Win7.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Scroff.Win7.ViewModels"
        xmlns:conv="clr-namespace:Scroff.Win7.Converters"
        Title="Scroff · 屏幕定时开关"
        Width="520" Height="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#F4F6FA"
        FontFamily="Microsoft YaHei UI, Segoe UI">

    <Window.Resources>
        <conv:ScheduleActionToTextConverter x:Key="ActionToTextConverter"/>
        <conv:ScheduleActionToColorConverter x:Key="ActionToColorConverter"/>
        <conv:BoolToOnOffConverter x:Key="BoolToOnOffConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
        <conv:EditModeToTitleConverter x:Key="EditTitleConverter"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4F7CFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D6AEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#5B6478"/>
            <Setter Property="BorderBrush" Value="#E0E4EC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0F2F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerTextButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Foreground" Value="#E5484D"/>
            <Setter Property="BorderBrush" Value="#F3C2C4"/>
        </Style>

        <Style x:Key="AccentTextButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Foreground" Value="#4F7CFF"/>
            <Setter Property="BorderBrush" Value="#C9D5FF"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E4EC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4F7CFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="16" Height="16" VerticalAlignment="Center">
                                <Ellipse x:Name="Outer" Width="16" Height="16"
                                         Stroke="#B5BBC9" StrokeThickness="1.5" Fill="White"/>
                                <Ellipse x:Name="Inner" Width="8" Height="8"
                                         Fill="#4F7CFF" Visibility="Collapsed"/>
                            </Grid>
                            <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center"
                                              TextElement.Foreground="#3A4256"
                                              TextElement.FontSize="13"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Inner" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Outer" Property="Stroke" Value="#4F7CFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Border Width="36" Height="36" CornerRadius="8" Background="#4F7CFF">
                <TextBlock Text="S" FontSize="20" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Scroff" FontSize="18" FontWeight="Bold" Foreground="#1A2233"/>
                <TextBlock Text="屏幕定时开关控制器 (Win 7 兼容版)" FontSize="12" Foreground="#7A8499" Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- 添加/编辑任务面板 -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="18" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="{Binding IsEditing, Converter={StaticResource EditTitleConverter}}"
                           FontSize="15" FontWeight="Bold" Foreground="#1A2233" Margin="0,0,0,14"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="任务名称（可选）" FontSize="12" Foreground="#7A8499" Margin="0,0,0,6"/>
                    <TextBox Grid.Row="1" Grid.Column="0"
                             Text="{Binding NewScheduleName, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="时间" FontSize="12" Foreground="#7A8499" Margin="12,0,0,6"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{Binding NewScheduleTime, StringFormat='{}{0:hh\\:mm}', UpdateSourceTrigger=LostFocus}"
                             Width="100" Margin="12,0,0,0"/>

                    <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,14,0,0">
                        <RadioButton Content="关闭屏幕" GroupName="ScheduleAction" IsChecked="{Binding IsScreenOffAction}"/>
                        <RadioButton Content="打开屏幕" GroupName="ScheduleAction"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Content="取消" Style="{StaticResource GhostButton}" Command="{Binding CancelEditCommand}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}}"
                                Margin="0,0,8,0"/>
                        <Button Content="保存" Style="{StaticResource PrimaryButton}" Command="{Binding AddScheduleCommand}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 任务列表与设置 -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="2,0,2,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="定时任务" FontSize="14" FontWeight="SemiBold" Foreground="#1A2233" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="开机自启动" FontSize="13" Foreground="#3A4256" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Grid x:Name="AutoStartSwitch" Width="46" Height="24" Cursor="Hand"
                          MouseLeftButtonUp="OnAutoStartToggleClick">
                        <Border x:Name="AutoStartTrack" CornerRadius="12" Background="#C9D0DC"/>
                        <Border x:Name="AutoStartThumb" Width="20" Height="20" CornerRadius="10"
                                Background="White" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Grid>

            <ListBox x:Name="SchedulesList" Grid.Row="1" ItemsSource="{Binding Schedules}"
                     BorderThickness="0" Background="Transparent"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="10" Padding="14" BorderBrush="#E5E9F2" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                             Fill="{Binding Action, Converter={StaticResource ActionToColorConverter}}"/>
                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="#1A2233" Margin="8,0,0,0"/>
                                    <Border CornerRadius="10" Padding="8,2" Margin="10,0,0,0" Background="#EEF2FF">
                                        <TextBlock Text="{Binding Action, Converter={StaticResource ActionToTextConverter}}"
                                                   FontSize="11" Foreground="#4F7CFF" FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="启用" FontSize="12" Foreground="#7A8499" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Grid Width="38" Height="20" Cursor="Hand" Tag="{Binding}"
                                          Background="Transparent" MouseLeftButtonUp="OnEnabledToggleClick">
                                        <Border x:Name="EnTrack" CornerRadius="10">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#C9D0DC"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                            <Setter Property="Background" Value="#4F7CFF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <Border x:Name="EnThumb" Width="16" Height="16" CornerRadius="8"
                                                Background="White" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Margin" Value="2,0,0,0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                            <Setter Property="Margin" Value="20,0,0,0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Time, StringFormat='{}{0:hh\\:mm}'}"
                                               FontSize="32" FontWeight="Bold" Foreground="#1A2233"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,8,0,0">
                                    <Button Content="执行" Style="{StaticResource AccentTextButton}"
                                            Command="{Binding DataContext.ExecuteScheduleCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}" Margin="0,0,6,0"/>
                                    <Button Content="编辑" Style="{StaticResource GhostButton}"
                                            Command="{Binding DataContext.EditScheduleCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}" Margin="0,0,6,0"/>
                                    <Button Content="删除" Style="{StaticResource DangerTextButton}"
                                            Command="{Binding DataContext.DeleteScheduleCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</Window>
