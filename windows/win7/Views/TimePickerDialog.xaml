<Window x:Class="Scroff.Win7.Views.TimePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择时间"
        Width="320" Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        Background="#F4F6FA"
        FontFamily="Microsoft YaHei UI, Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="请选择执行时间" FontSize="14" FontWeight="SemiBold"
                   Foreground="#1A2233" Margin="0,0,0,14"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="时" FontSize="12" Foreground="#7A8499" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBox x:Name="HourBox" Width="70" Height="50" FontSize="32" FontWeight="Bold"
                         TextAlignment="Center" VerticalContentAlignment="Center"
                         PreviewTextInput="OnHourTextInput"/>
            </StackPanel>
            <TextBlock Text=":" FontSize="36" FontWeight="Bold" VerticalAlignment="Center"
                       Foreground="#1A2233" Margin="8,18,8,0"/>
            <StackPanel>
                <TextBlock Text="分" FontSize="12" Foreground="#7A8499" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBox x:Name="MinuteBox" Width="70" Height="50" FontSize="32" FontWeight="Bold"
                         TextAlignment="Center" VerticalContentAlignment="Center"
                         PreviewTextInput="OnMinuteTextInput"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="取消" Width="80" Margin="0,0,8,0" Click="OnCancelClick"
                    Background="White" Foreground="#5B6478" BorderBrush="#E0E4EC" BorderThickness="1"
                    Padding="0,6" Cursor="Hand"/>
            <Button Content="确定" Width="80" Click="OnOkClick" IsDefault="True"
                    Background="#4F7CFF" Foreground="White" BorderThickness="0"
                    Padding="0,6" Cursor="Hand" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
