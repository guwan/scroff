<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!--
      优先使用本地 NuGet 缓存（%USERPROFILE%\.nuget\packages），
      避免构建时联网下载依赖（内网/离线环境也能 build）。
      如果需要联网获取新版本，请恢复 nuget.org 源。
    -->
    <add key="local-cache" value="%USERPROFILE%\.nuget\packages" />
  </packageSources>
</configuration>
