# =============================================================
# 行尾规范化（避免跨平台 CRLF/LF 问题）
# =============================================================
# Shell 脚本必须保持 LF
*.sh          text eol=lf
# Gradle 包装器脚本保持 LF
gradlew       text eol=lf
gradlew.bat   text eol=crlf
# Windows 批处理保持 CRLF
*.bat         text eol=crlf
*.cmd         text eol=crlf
*.ps1         text eol=crlf
# 配置文件统一 LF
*.yml         text eol=lf
*.yaml        text eol=lf
*.json        text eol=lf
*.properties  text eol=lf
*.xml         text eol=lf
*.kts         text eol=lf
*.java        text eol=lf
*.kt          text eol=lf
*.cs          text eol=lf
*.csproj      text eol=lf
*.sln         text eol=crlf
*.md          text eol=lf
